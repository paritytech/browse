{
  "name": "@parity/browse-client",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "postinstall": "papi generate",
    "dev": "vite",
    "dev:paseo": "APP_DEBUG=true NETWORK_GENESIS_HASH=0xbf0488dbe9daa1de1c08c5f743e26fdc2a4ecd74cf87dd1b4b1eeb99ae4ef19f vite --port 3000",
    "dev:previewnet": "APP_DEBUG=true NETWORK_GENESIS_HASH=0x29f7b15e6227f86b90bf5199b5c872c28649a30e5f15fae6dd8fa9d5d48d6fbb vite --port 3000",
    "dev:widget:paseo": "APP_DEBUG=true NETWORK_GENESIS_HASH=0xbf0488dbe9daa1de1c08c5f743e26fdc2a4ecd74cf87dd1b4b1eeb99ae4ef19f vite --open /widget.html",
    "dev:widget:previewnet": "APP_DEBUG=true NETWORK_GENESIS_HASH=0x29f7b15e6227f86b90bf5199b5c872c28649a30e5f15fae6dd8fa9d5d48d6fbb vite --open /widget.html",
    "build": "bun run build:spa && bun run build:widget",
    "build:spa": "APP_BUILD_TARGET=spa vite build --outDir dist/spa --emptyOutDir",
    "build:widget": "APP_BUILD_TARGET=widget vite build --outDir dist/widget --emptyOutDir && mv dist/widget/widget.html dist/widget/index.html",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "papi:paseo:hub": "npx papi add -w wss://paseo-asset-hub-next-rpc.polkadot.io paseohub",
    "papi:previewnet:hub": "npx papi add -w wss://previewnet.substrate.dev/asset-hub previewnethub",
    "papi:summitnet:hub": "npx papi add -w wss://summit-asset-hub-rpc.polkadot.io summithub",
    "papi:attestation-service": "npx papi sol add src/lib/abis/AttestationService.json attestation_service",
    "papi:schema-registry": "npx papi sol add src/lib/abis/SchemaRegistry.json schema_registry",
    "test:e2e": "APP_PGAS_FUNDING_TIMEOUT=1000 NETWORK_GENESIS_HASH=0x29f7b15e6227f86b90bf5199b5c872c28649a30e5f15fae6dd8fa9d5d48d6fbb playwright test --config tests/playwright.config.ts"
  },
  "dependencies": {
    "@ensdomains/content-hash": "^3.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/martian-mono": "^5.2.7",
    "@noble/hashes": "^2.0.1",
    "@novasamatech/host-api-wrapper": "0.8.3",
    "@parity/browse-sdk": "*",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-api/sdk-ink": "^0.7.0",
    "@polkadot-api/signers-common": "^0.2.2",
    "@polkadot-api/substrate-bindings": "^0.20.2",
    "@polkadot-api/utils": "^0.4.0",
    "@preact/preset-vite": "^2.10.5",
    "@tanstack/react-query": "^5.96.2",
    "buffer": "^6.0.3",
    "lucide-preact": "^1.8.0",
    "polkadot-api": "^2.1.2",
    "preact": "^10.29.1",
    "smoldot": "^2.0.40",
    "viem": "^2.50.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@parity/host-api-test-sdk": "^0.9.0",
    "@playwright/test": "^1.59.1",
    "@polkadot-labs/hdkd": "^0.0.27",
    "@polkadot-labs/hdkd-helpers": "^0.0.28",
    "@polkadot/api": "^16.5.4",
    "@polkadot/keyring": "^14.0.2",
    "@polkadot/util": "^14.0.2",
    "@polkadot/util-crypto": "^14.0.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "ws": "^8.20.0"
  }
}
