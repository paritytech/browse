{
  "permissions": {
    "allow": [
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm test:*)",
      "Bash(npm run format:*)",
      "Bash(npm run dev:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(gh:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(bun run typecheck)",
      "Bash(bun run lint)",
      "Bash(bun run format:check)",
      "Bash(gh run watch:*)",
      "Bash(yarn typecheck)",
      "Bash(bun pm view:*)",
      "Bash(npm view:*)",
      "mcp__sentry__search_events",
      "mcp__claude_ai_Mermaid_Chart__validate_and_render_mermaid_diagram"
    ],
    "deny": []
  },
  "env": {
    "PATH": "/opt/homebrew/bin:/Users/tiago/.bun/bin:/Users/tiago/.nvm/versions/node/v22.13.1/bin:/Users/tiago/.pyenv/versions/3.11.8/bin:/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Session started at $(date). Branch: $(git branch --show-current 2>/dev/null || echo 'N/A'). Last commit: $(git log --oneline -1 2>/dev/null || echo 'N/A').\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"If there is remaining work, keep going. Check your task list.\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run format 2>/dev/null || npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
