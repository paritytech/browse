{
  "name": "browse-contracts-scripts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cd .. && forge build",
    "deploy-publisher": "npm run build && tsx --env-file-if-exists=../.env deploy-publisher.ts",
    "deploy-resolver": "npm run build && tsx --env-file-if-exists=../.env deploy-resolver.ts",
    "register-schema": "tsx --env-file-if-exists=../.env register-schema.ts",
    "publish-app": "tsx --env-file-if-exists=../.env publish-app.ts"
  },
  "dependencies": {
    "@polkadot-labs/hdkd": "^0.0.25",
    "@polkadot-labs/hdkd-helpers": "^0.0.26",
    "polkadot-api": "^1.23.1",
    "viem": "^2.43.4"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
