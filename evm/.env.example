# Required. Target network, selected by genesis hash.
# Supported values are defined in scripts/network.ts.
GENESIS_HASH=

# Optional. HD derivation path. Defaults to "//Alice" when MNEMONIC is unset.
# DERIVATION_PATH=

# Pass deploy secrets inline, never store them here:
#   MNEMONIC="..." make deploy-publisher   (defaults to the //Alice dev key)
#   PRIVATE_KEY=0x... for the Foundry and Hardhat scripts

# For `make deploy-resolver`: the AttestationService the resolver binds to.
# ATTESTATION_SERVICE=0x...

# For `make register-schema`: the SchemaRegistry and the schema to register.
# RESOLVER is optional and binds the schema to a resolver (defaults to none).
# SCHEMA_REGISTRY=0x...
# SCHEMA="bool like"
# RESOLVER=0x...
