# BIP39 mnemonic.
MNEMONIC="your twelve word mnemonic phrase here"

# Optional. HD derivation path.
# DERIVATION_PATH=

# Target network genesis hash.
NETWORK_GENESIS_HASH=0xbf0488dbe9daa1de1c08c5f743e26fdc2a4ecd74cf87dd1b4b1eeb99ae4ef19f

# Target DotNS domain, the bare label without the `.dot` suffix (e.g. `browse`).
APP_DOTNS_DOMAIN=browse

# Identity backend for username search.
APP_IDENTITY_API_URL=https://identity-backend-next.parity-testnet.parity.io/api/v1

# Enable/ disable client debug logging.
APP_DEBUG=false

# https://github.com/paritytech/attestation-protocol/blob/main/evm/contracts/AttestationService.sol
# ATTESTATION_SERVICE=

# https://github.com/paritytech/attestation-protocol/blob/main/evm/contracts/SchemaRegistry.sol
# SCHEMA_REGISTRY=

# https://github.com/paritytech/browse/blob/main/evm/src/RecipientAndAttesterIndexResolver.sol
# RESOLVER=

# Optional. Schema registration flags. Defaults: REVOCABLE=true, UNIQUE=false.
# REVOCABLE=true
# UNIQUE=false

# Optional. Set to 1 to publish the deployment, listing the domain in the Publisher registry. Defaults to off.
# PUBLISH=1